{
  "name": "touch-grass",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "prebuild": "pnpm lint:brutal",
    "build": "pnpm -r build",
    "lint:brutal": "node scripts/lint-brutal.mjs",
    "test": "pnpm -r test",
    "dev": "pnpm --filter @touch-grass-ds/docs-site dev",
    "tokens": "pnpm --filter @touch-grass-ds/tokens build",
    "generate": "node scripts/generate.mjs",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "typescript": "^5.6.0"
  }
}

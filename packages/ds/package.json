{
  "name": "@touch-grass-ds/react",
  "version": "1.0.0",
  "description": "React 19 component library for Touch Grass — brutalist primitives and patterns. Zero rounded corners, zero motion, tokens only.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles/base.css": "./src/styles/base.css"
  },
  "keywords": [
    "design-system",
    "react",
    "components",
    "brutalism",
    "tailwindcss",
    "ui",
    "touch-grass"
  ],
  "author": "Thiago Xikota",
  "homepage": "https://github.com/thiagoxikota/touch-grass#readme",
  "bugs": {
    "url": "https://github.com/thiagoxikota/touch-grass/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thiagoxikota/touch-grass.git",
    "directory": "packages/ds"
  },
  "files": [
    "dist",
    "src/styles",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup",
    "test": "vitest run"
  },
  "dependencies": {
    "@touch-grass-ds/tokens": "workspace:*",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.5.0",
    "@fontsource/geist-sans": "^5.1.0",
    "@fontsource/geist-mono": "^5.1.0",
    "@radix-ui/react-slot": "^1.1.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "@types/react": "^19.0.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vitest": "^2.1.0",
    "vitest-axe": "^0.1.0",
    "axe-core": "^4.10.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.6.0",
    "@playwright/experimental-ct-react": "^1.43.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@touch-grass-ds/tokens": "workspace:*"
  }
}
